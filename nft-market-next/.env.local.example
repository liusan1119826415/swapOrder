# Pinata IPFS Configuration
# Get your credentials from: https://app.pinata.cloud/developers

# Option 1: Using JWT (Recommended)
NEXT_PUBLIC_PINATA_JWT=your_jwt_token_here

# Option 2: Using API Key + Secret Key (Legacy method)
NEXT_PUBLIC_PINATA_API_KEY=your_api_key_here
NEXT_PUBLIC_PINATA_SECRET_KEY=your_secret_key_here

# Optional: Custom IPFS Gateway (default: https://gateway.pinata.cloud)
# NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io
